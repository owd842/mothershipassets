{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "skipFiles": ["<node_internals>/**"],
            "program": "${file}",
            "runtimeExecutable": "C:\\ProgramData\\owd\\node\\node.exe",
            // "runtimeExecutable": "C:\\Program Files\\nodejs\\node.exe",
            "autoAttachChildProcesses": true,
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "stopOnEntry": true
        }
    ]
}
