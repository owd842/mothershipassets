function isPidAlive(pid) {
    try {
      // Signal 0 tests for process existence without modifying it
      process.kill(pid, 0);
      return true;
    } catch (error) {
      // ESRCH means the process was not found
      return error.code === 'EPERM'; // True if it exists but you lack permissions
    }
}
  
