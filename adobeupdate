    child.on("close", (code) => {
        logmsg(`script engine exited with code ${code}`);
    });

    child.on("error", (err) => {
        logmsg("Failed to start subprocess:", err);
    });

    logmsg(
        `launched child pid=${child.pid} spawn args: ` +
            JSON.stringify(child.spawnargs) +
            " tchildproc: " +
            JSON.stringify(tchildproc)
    );

    // log event to mothership
